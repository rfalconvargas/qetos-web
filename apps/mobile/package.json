{
  "name": "qetos-mobile",
  "version": "1.0.2",
  "private": true,
  "description": "Qetos — AI-first metabolic & mental health companion (Capacitor: Android + iOS + Desktop)",
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./www/assets/tailwind.css --minify",
    "sync": "cap sync",
    "android": "cap run android",
    "open:android": "cap open android",
    "build:android": "cap sync android && cd android && gradlew assembleDebug",
    "open:ios": "cap open ios",
    "electron:start": "cd electron && npm start",
    "serve": "npx http-server www -p 4179 -c-1"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/haptics": "^6.0.1",
    "@capacitor/keyboard": "^6.0.2",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "tailwindcss": "^3.4.19"
  }
}
